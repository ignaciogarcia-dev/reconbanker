DATABASE_URL=postgresql://reconbanker:reconbanker@localhost:5432/reconbanker
REDIS_URL=redis://localhost:6379
PORT=3000
NODE_ENV=development

POLLING_INTERVAL_SECONDS=600
SCRAPE_INTERVAL_SECONDS=1200
EXPIRE_STALE_REQUESTS_INTERVAL_SECONDS=3600
BANK_SCRAPE_CONCURRENCY=2

# Per-phase timeouts (ms) bounding a single scrape so a hung browser can't wedge
# the queue. Defaults shown; uncomment to override.
# BANK_SCRAPE_LAUNCH_TIMEOUT_MS=60000
# BANK_SCRAPE_SCRIPT_TIMEOUT_MS=600000
# BANK_SCRAPE_CLOSE_TIMEOUT_MS=30000
# BANK_SCRAPE_RUN_TIMEOUT_MS=780000

JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=12h
CREDENTIALS_ENCRYPTION_KEY=change_this_generate_with_openssl_rand_base64_32
CORS_ORIGINS=https://app.example.com

PLAYWRIGHT_HEADLESS=true

# WEBHOOK_QUEUE_ATTEMPTS=12
# WEBHOOK_QUEUE_BACKOFF_MS=10000
